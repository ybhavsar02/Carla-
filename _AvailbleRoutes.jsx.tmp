const convertMinsToReadable = mins => {
  if (!mins || mins <= 0) return "0 Minutes";
  const hours = Math.floor(mins / 60);
  const minutes = mins % 60;

  if (hours > 0 && minutes > 0) {
    return `${hours} Hours ${minutes} Minutes`;
  } else if (hours > 0) {
    return `${hours} Hours`;
  } else {
    return `${minutes} Minutes`;
  }
};
